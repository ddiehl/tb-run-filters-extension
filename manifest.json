{
  "manifest_version": 2,
  "name": "Run Filters on Current Folder",
  "version": "1.0",
  "description": "Adds a toolbar button to run message filters on the currently displayed folder.",
  "browser_specific_settings": {
    "gecko": {
      "id": "run-filters@example.net",
      "strict_min_version": "128.0"
    }
  },
  "background": {
    "scripts": ["background.js"]
  },
  "permissions": [
    "accountsRead",
    "messagesRead"
  ],
  "browser_action": {
    "default_title": "Run Filters on This Folder",
    "default_icon": "icons/icon.svg",
    "default_label": "Run Filters"
  },
  "experiment_apis": {
    "RunFilters": {
      "schema": "experiment/RunFilters/schema.json",
      "parent": {
        "scopes": ["addon_parent"],
        "paths": [["RunFilters"]],
        "script": "experiment/RunFilters/implementation.js"
      }
    }
  }
}
